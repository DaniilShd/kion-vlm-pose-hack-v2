/data
/cache

# Но сохраняем структуру папок (git сохранит пустые папки)
!/data/uploads/.gitkeep
!/data/results/.gitkeep
!/data/test_videos/.gitkeep

# Models (обычно большие файлы)
/models/*
!/models/.gitkeep

